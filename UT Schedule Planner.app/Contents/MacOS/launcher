#!/usr/bin/env bash
set -e

# Navigate to the project root (3 levels up from Contents/MacOS/)
DIR="$(cd "$(dirname "$0")/../../.."; pwd)"
cd "$DIR"

# Check for Python
if ! command -v python3 &> /dev/null; then
    osascript -e 'display dialog "Python 3 is not installed.\n\nInstall with:\n  brew install python3\n\nOr download from python.org/downloads" with title "UT Schedule Planner" buttons {"OK"} default button "OK" with icon caution'
    exit 1
fi

# Create venv if needed
if [ ! -d ".venv" ]; then
    python3 -m venv .venv
fi

source .venv/bin/activate

# Install dependencies if needed
if ! python -c "import flask" 2>/dev/null; then
    pip install -r requirements.txt
    playwright install chromium
fi

# Open browser after a short delay
(sleep 2 && open http://localhost:5000) &

# Start the server
exec python app.py
